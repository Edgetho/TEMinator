# Run the TEMinator app from the command line. This is a convenient way to
# ensure teminator runs in the environment defined by environment.yml.

set -euo pipefail

SCRIPT_SOURCE="$0"
if [[ -n "${BASH_VERSION:-}" ]]; then
  SCRIPT_SOURCE="${BASH_SOURCE[0]}"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
ENV_FILE_BASE="$SCRIPT_DIR/environment.yml"
ENV_FILE_LINUX="$SCRIPT_DIR/environment.linux.yml"
ENV_FILE="$ENV_FILE_BASE"
APP_FILE="$SCRIPT_DIR/app.py"

if [[ "$(uname -s)" == "Linux" && -f "$ENV_FILE_LINUX" ]]; then
  ENV_FILE="$ENV_FILE_LINUX"
fi

print_help() {
  cat <<EOF
Usage: $(basename "$0") [--debug-qt] [--build-env] [--help] [app-args...]

Runs TEMinator inside the conda/mamba environment defined by environment.yml.
On Linux, if environment.linux.yml exists, the launcher uses it automatically.

Options:
  --debug-qt      Enable Qt plugin debug logging for this run (QT_DEBUG_PLUGINS=1).
  --build-env     Build the envioronment and exit.
  --force-x11     Force Qt platform backend to X11/xcb for this run.
  --force-software
                  Force software rendering (disable hardware acceleration).
  -v, --verbose
                  Enable verbose TEMinator debug logging (forwarded to app.py).
  -v2, --verbose2
                  Enable export/render trace diagnostics (sets TEMINATOR_EXPORT_TRACE=1).
  -h, --help      Show this help message and exit.

Examples:
  $(basename "$0")
  $(basename "$0") --build-env
  $(basename "$0") --debug-qt
  $(basename "$0") --force-x11
  $(basename "$0") --force-software
  $(basename "$0") --verbose
  $(basename "$0") -v2
  $(basename "$0") /path/to/image.dm4
  $(basename "$0") --debug-qt --force-x11 --verbose -v2 /path/to/image.dm4

Notes:
  - All non-launcher arguments are forwarded to app.py.
  - On Linux, the launcher also applies Qt env guards to avoid mixed
    system/conda plugin ABI issues and prefers Wayland/OpenGL when available.
  - For Wayland setup details, see README.md ("Linux Wayland setup (optional)").
EOF
}

ENABLE_QT_DEBUG=0
ENABLE_APP_VERBOSE=0
ENABLE_TRACE_VERBOSE2=0
FORCE_BUILD_ENV=0
FORCE_X11=0
FORCE_SOFTWARE=0
SHOW_HELP=0
APP_ARGS=()

for arg in "$@"; do
  case "$arg" in
    --debug-qt)
      ENABLE_QT_DEBUG=1
      ;;
    --build-env)
      FORCE_BUILD_ENV=1
      ;;
    --force-x11)
      FORCE_X11=1
      ;;
    --force-software)
      FORCE_SOFTWARE=1
      ;;
    -v|--verbose)
      ENABLE_APP_VERBOSE=1
      ;;
    -v2|--verbose2)
      ENABLE_TRACE_VERBOSE2=1
      ;;
    -h|--help)
      SHOW_HELP=1
      ;;
    *)
      APP_ARGS+=("$arg")
      ;;
  esac
done

if [[ "$SHOW_HELP" -eq 1 ]]; then
  print_help
  exit 0
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Error: environment.yml not found at: $ENV_FILE"
  exit 1
fi

if [[ ! -f "$APP_FILE" ]]; then
  echo "Error: app.py not found at: $APP_FILE"
  exit 1
fi

ENV_NAME="$(awk -F': *' '/^name:/ {print $2; exit}' "$ENV_FILE" | tr -d '"' | tr -d "'")"

if [[ -z "${ENV_NAME:-}" ]]; then
  echo "Error: Could not read environment name from $ENV_FILE (expected: name: <env>)"
  exit 1
fi

if command -v mamba >/dev/null 2>&1; then
  PKG_MGR="mamba"
elif command -v conda >/dev/null 2>&1; then
  PKG_MGR="conda"
else
  echo "Error: Neither 'mamba' nor 'conda' is available in PATH."
  exit 1
fi

prompt_yes_no() {
  local prompt="$1"
  local reply
  local reply_lower

  while true; do
    printf "%s [yes/no]: " "$prompt"
    IFS= read -r reply
    reply_lower="$(printf '%s' "$reply" | tr '[:upper:]' '[:lower:]')"

    case "$reply_lower" in
      y|yes)
        return 0
        ;;
      n|no)
        return 1
        ;;
      *)
        echo "Please answer 'yes' or 'no'."
        ;;
    esac
  done
}

build_environment(){
    if prompt_yes_no "Create environment '$ENV_NAME' from $(basename "$ENV_FILE") now?"; then
      "$PKG_MGR" env create -f "$ENV_FILE"
    else
      echo "Environment creation canceled."
      return 1
    fi

    if ! "$PKG_MGR" env list | awk '{print $1}' | grep -Fxq "$ENV_NAME"; then
      echo "Error: Environment '$ENV_NAME' is still unavailable after creation attempt."
      return 1
    fi
    return 0
}

#check if we are forcing and environment build and if so, do so and exit
check_environment() {
    if [[ "$FORCE_BUILD_ENV" -ne 0 ]]; then
        build_environment
        return 1
    else
        if "$PKG_MGR" env list | awk '{print $1}' | grep -Fxq "$ENV_NAME"; then
        return 0
        fi

        echo "Environment '$ENV_NAME' is not installed."
        echo "You may install it automatically now:"
        build_environment
    fi
}

check_environment

qt_wayland_platform_available() {
  "$PKG_MGR" run -n "$ENV_NAME" python - <<'PY' >/dev/null 2>&1
from pathlib import Path

try:
  from PyQt5 import QtCore
except Exception:
  raise SystemExit(1)

plugins_path = Path(QtCore.QLibraryInfo.location(QtCore.QLibraryInfo.PluginsPath))
platform_dir = plugins_path / "platforms"
if not platform_dir.is_dir():
  raise SystemExit(1)

for candidate in platform_dir.iterdir():
  name = candidate.name.lower()
  if "wayland" in name and candidate.is_file():
    raise SystemExit(0)

raise SystemExit(1)
PY
}

# Build one launch command (avoids duplicated Linux/non-Linux exec blocks).
set -- "$PKG_MGR" run -n "$ENV_NAME" env \
  -u QT_PLUGIN_PATH \
  -u QT_QPA_PLATFORM_PLUGIN_PATH \
  -u QML2_IMPORT_PATH

if [[ "$(uname -s)" == "Linux" ]]; then
  if [[ "$FORCE_X11" -eq 1 ]]; then
    QT_PLATFORM_DEFAULT="xcb"
    # Explicitly unset QT_QPA_PLATFORM to prevent inheritance from parent shell
    unset QT_QPA_PLATFORM
  # Prefer Wayland first (when the session is Wayland) but keep xcb fallback.
  elif [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    if qt_wayland_platform_available; then
      QT_PLATFORM_DEFAULT="wayland;xcb"
    else
      QT_PLATFORM_DEFAULT="xcb"
    fi
  else
    QT_PLATFORM_DEFAULT="xcb"
  fi

  set -- "$@" \
    QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-$QT_PLATFORM_DEFAULT}" \
    QT_XCB_GL_INTEGRATION="${QT_XCB_GL_INTEGRATION:-xcb_egl}" \
    QT_OPENGL="${QT_OPENGL:-desktop}"
fi

if [[ "$ENABLE_QT_DEBUG" -eq 1 ]]; then
  set -- "$@" QT_DEBUG_PLUGINS=1
fi

if [[ "$ENABLE_TRACE_VERBOSE2" -eq 1 ]]; then
  set -- "$@" TEMINATOR_EXPORT_TRACE=1
fi

set -- "$@" python "$APP_FILE"

if [[ "$FORCE_X11" -eq 1 ]]; then
  set -- "$@" --force-x11
fi

if [[ "$FORCE_SOFTWARE" -eq 1 ]]; then
  set -- "$@" --force-software
fi

if [[ "$ENABLE_APP_VERBOSE" -eq 1 ]]; then
  set -- "$@" --verbose
fi

if [[ "$ENABLE_TRACE_VERBOSE2" -eq 1 ]]; then
  set -- "$@" --verbose2
fi

if [[ ${#APP_ARGS[@]} -gt 0 ]]; then
  set -- "$@" "${APP_ARGS[@]}"
fi

exec "$@"
