# Run the TEM Companion app from the command line. This is a convenient way to
# ensure temcompanion runs in the environment defined by environment.yml.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/environment.yml"
APP_FILE="$SCRIPT_DIR/app.py"

print_help() {
  cat <<EOF
Usage: $(basename "$0") [--debug-qt] [--help] [app-args...]

Runs TEMinator inside the conda/mamba environment defined by environment.yml.

Options:
  --debug-qt      Enable Qt plugin debug logging for this run (QT_DEBUG_PLUGINS=1).
  --force-x11     Force Qt platform backend to X11/xcb for this run.
  --force-software
                  Force software rendering (disable hardware acceleration).
  -v, --verbose
                  Enable verbose TEMinator debug logging (forwarded to app.py).
  -h, --help      Show this help message and exit.

Examples:
  $(basename "$0")
  $(basename "$0") --debug-qt
  $(basename "$0") --force-x11
  $(basename "$0") --force-software
  $(basename "$0") --verbose
  $(basename "$0") /path/to/image.dm4
  $(basename "$0") --debug-qt --force-x11 --verbose /path/to/image.dm4

Notes:
  - All non-launcher arguments are forwarded to app.py.
  - On Linux, the launcher also applies Qt env guards to avoid mixed
    system/conda plugin ABI issues and prefers Wayland/OpenGL when available.
  - For Wayland setup details, see README.md ("Linux Wayland setup (optional)").
EOF
}

ENABLE_QT_DEBUG=0
ENABLE_APP_VERBOSE=0
FORCE_X11=0
FORCE_SOFTWARE=0
SHOW_HELP=0
APP_ARGS=()

for arg in "$@"; do
  case "$arg" in
    --debug-qt)
      ENABLE_QT_DEBUG=1
      ;;
    --force-x11)
      FORCE_X11=1
      ;;
    --force-software)
      FORCE_SOFTWARE=1
      ;;
    -v|--verbose)
      ENABLE_APP_VERBOSE=1
      ;;
    -h|--help)
      SHOW_HELP=1
      ;;
    *)
      APP_ARGS+=("$arg")
      ;;
  esac
done

if [[ "$SHOW_HELP" -eq 1 ]]; then
  print_help
  exit 0
fi

if [[ ! -f "$ENV_FILE" ]]; then
  echo "Error: environment.yml not found at: $ENV_FILE"
  exit 1
fi

if [[ ! -f "$APP_FILE" ]]; then
  echo "Error: app.py not found at: $APP_FILE"
  exit 1
fi

ENV_NAME="$(awk -F': *' '/^name:/ {print $2; exit}' "$ENV_FILE" | tr -d '"' | tr -d "'")"

if [[ -z "${ENV_NAME:-}" ]]; then
  echo "Error: Could not read environment name from $ENV_FILE (expected: name: <env>)"
  exit 1
fi

if command -v mamba >/dev/null 2>&1; then
  PKG_MGR="mamba"
elif command -v conda >/dev/null 2>&1; then
  PKG_MGR="conda"
else
  echo "Error: Neither 'mamba' nor 'conda' is available in PATH."
  exit 1
fi

if ! "$PKG_MGR" env list | awk '{print $1}' | grep -Fxq "$ENV_NAME"; then
  echo "Error: Environment '$ENV_NAME' is not installed."
  echo "Create it with:"
  echo "  $PKG_MGR env create -f \"$ENV_FILE\""
  exit 1
fi

qt_wayland_platform_available() {
  "$PKG_MGR" run -n "$ENV_NAME" python - <<'PY' >/dev/null 2>&1
from pathlib import Path

try:
  from PyQt5 import QtCore
except Exception:
  raise SystemExit(1)

plugins_path = Path(QtCore.QLibraryInfo.location(QtCore.QLibraryInfo.PluginsPath))
platform_dir = plugins_path / "platforms"
if not platform_dir.is_dir():
  raise SystemExit(1)

for candidate in platform_dir.iterdir():
  name = candidate.name.lower()
  if "wayland" in name and candidate.is_file():
    raise SystemExit(0)

raise SystemExit(1)
PY
}

# Build one launch command (avoids duplicated Linux/non-Linux exec blocks).
set -- "$PKG_MGR" run -n "$ENV_NAME" env \
  -u QT_PLUGIN_PATH \
  -u QT_QPA_PLATFORM_PLUGIN_PATH \
  -u QML2_IMPORT_PATH

if [[ "$(uname -s)" == "Linux" ]]; then
  if [[ "$FORCE_X11" -eq 1 ]]; then
    QT_PLATFORM_DEFAULT="xcb"
    # Explicitly unset QT_QPA_PLATFORM to prevent inheritance from parent shell
    unset QT_QPA_PLATFORM
  # Prefer Wayland first (when the session is Wayland) but keep xcb fallback.
  elif [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    if qt_wayland_platform_available; then
      QT_PLATFORM_DEFAULT="wayland;xcb"
    else
      QT_PLATFORM_DEFAULT="xcb"
    fi
  else
    QT_PLATFORM_DEFAULT="xcb"
  fi

  set -- "$@" \
    QT_QPA_PLATFORM="${QT_QPA_PLATFORM:-$QT_PLATFORM_DEFAULT}" \
    QT_XCB_GL_INTEGRATION="${QT_XCB_GL_INTEGRATION:-xcb_egl}" \
    QT_OPENGL="${QT_OPENGL:-desktop}"
fi

if [[ "$ENABLE_QT_DEBUG" -eq 1 ]]; then
  set -- "$@" QT_DEBUG_PLUGINS=1
fi

set -- "$@" python "$APP_FILE"

if [[ "$FORCE_X11" -eq 1 ]]; then
  set -- "$@" --force-x11
fi

if [[ "$FORCE_SOFTWARE" -eq 1 ]]; then
  set -- "$@" --force-software
fi

if [[ "$ENABLE_APP_VERBOSE" -eq 1 ]]; then
  set -- "$@" --verbose
fi

if [[ ${#APP_ARGS[@]} -gt 0 ]]; then
  set -- "$@" "${APP_ARGS[@]}"
fi

exec "$@"